# ============================================
# GigPulse Sentinel Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ----- Backend -----
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
DEBUG=true

# ----- Database -----
# Provide your PostgreSQL connection string here (e.g., Neon or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# For production (Supabase PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ----- External APIs -----
OPENWEATHERMAP_API_KEY=your-openweathermap-key
AQICN_API_KEY=your-aqicn-key
IMD_API_BASE_URL=http://localhost:8000/mock/imd
ZOMATO_API_BASE_URL=http://localhost:8000/mock/zomato

# ----- Payment -----
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ----- Mock API Mode -----
# Set to true to use built-in mock APIs instead of real external services
USE_MOCK_APIS=true

# ----- Security -----
AES_ENCRYPTION_KEY=your-32-byte-aes-key-here-change
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60

# ----- AI Agents (Cerebras) -----
CEREBRAS_API_KEY=your-cerebras-cloud-api-key

# ----- Notifications -----
SMS_API_KEY=your-sms-provider-key
SMS_SENDER_ID=GIGSHD

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000

# Email (SMTP)
# Gmail SMTP recommended settings (use an App Password for SMTP_PASSWORD)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
VITE_APP_NAME=GigPulse Sentinel
