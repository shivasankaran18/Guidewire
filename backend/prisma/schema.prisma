generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Zone {
  id                      String    @id @default(uuid())
  zone_code               String    @unique
  city                    String
  area_name               String
  sub_zone                String?
  latitude                Float
  longitude               Float
  radius_meters           Int       @default(500)
  flood_risk_score        Float     @default(0)
  heat_risk_score         Float     @default(0)
  aqi_risk_score          Float     @default(0)
  strike_frequency_yearly Float     @default(0)
  overall_risk_level      String    @default("LOW")
  is_active               Boolean   @default(true)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @default(now()) @updatedAt

  workers  Worker[]
  triggers Trigger[]

  @@map("zones")
}

model Worker {
  id                    String    @id @default(uuid())
  phone                 String    @unique
  name                  String
  platform              String?
  platform_worker_id    String?
  aadhaar_last4         String?
  aadhaar_hash          String?
  upi_id_hash           String?
  upi_id_masked         String?
  selfie_hash           String?
  device_fingerprint    String?
  device_model          String?
  zone_id               String?
  primary_zone_code     String?
  avg_daily_earnings    Float     @default(0)
  avg_weekly_earnings   Float     @default(0)
  tenure_weeks          Int       @default(0)
  trust_score           Float     @default(50.0)
  is_verified_partner   Boolean   @default(false)
  fraud_strikes         Int       @default(0)
  account_status        String    @default("PROBATION")
  probation_end_date    DateTime?
  role                  String    @default("WORKER")
  last_login_at         DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  zone                 Zone?              @relation(fields: [zone_id], references: [id])
  policies             Policy[]
  claims               Claim[]            @relation("WorkerClaims")
  reviewed_claims      Claim[]            @relation("ClaimReviewer")
  resolved_fraud_rings FraudRing[]        @relation("FraudRingResolver")
  payouts              Payout[]
  earnings_patterns    EarningsPattern[]
  movement_signatures  MovementSignature[]

  @@map("workers")
}

model Policy {
  id                  String    @id @default(uuid())
  worker_id           String
  plan_tier           String
  premium_amount      Float
  coverage_amount     Float
  coverage_multiplier Float
  week_start          String
  week_end            String
  status              String    @default("ACTIVE")
  payment_reference   String?
  payment_status      String    @default("PENDING")
  risk_factors        Json?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  worker Worker @relation(fields: [worker_id], references: [id])
  claims Claim[]

  @@map("policies")
}

model Trigger {
  id               String    @id @default(uuid())
  zone_id          String
  zone_code        String
  trigger_type     String
  severity         String
  threshold_value  Float?
  threshold_limit  Float?
  source_primary   String?
  source_secondary String?
  source_tertiary  String?
  sources_agreeing Int       @default(0)
  auto_approved    Boolean   @default(false)
  raw_data         Json?
  triggered_at     DateTime  @default(now())
  expires_at       DateTime?
  status           String    @default("ACTIVE")
  created_at       DateTime  @default(now())

  zone   Zone    @relation(fields: [zone_id], references: [id])
  claims Claim[]

  @@map("triggers")
}

model Claim {
  id                  String    @id @default(uuid())
  worker_id           String
  policy_id           String
  trigger_id          String
  zone_code           String
  claim_type          String
  disruption_hours    Float
  working_hours       Float     @default(10)
  earnings_for_slot   Float?
  calculated_payout   Float
  actual_payout       Float?
  payout_cap          Float?
  fraud_score         Float     @default(0)
  fraud_tier          String?
  confidence_score    Float?
  fraud_signals       Json?
  verification_method String?
  status              String    @default("PENDING")
  appeal_status       String?
  appeal_reason       String?
  reviewed_by         String?
  review_notes        String?
  claimed_at          DateTime  @default(now())
  resolved_at         DateTime?
  paid_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  worker   Worker   @relation("WorkerClaims", fields: [worker_id], references: [id])
  reviewer Worker?  @relation("ClaimReviewer", fields: [reviewed_by], references: [id])
  policy   Policy   @relation(fields: [policy_id], references: [id])
  trigger  Trigger  @relation(fields: [trigger_id], references: [id])
  payout   Payout?

  @@map("claims")
}

model Payout {
  id              String    @id @default(uuid())
  claim_id        String    @unique
  worker_id       String
  amount          Float
  upi_reference   String?
  payment_method  String    @default("UPI")
  payment_status  String    @default("PENDING")
  goodwill_credit Float     @default(0)
  paid_at         DateTime?
  created_at      DateTime  @default(now())

  claim  Claim  @relation(fields: [claim_id], references: [id])
  worker Worker @relation(fields: [worker_id], references: [id])

  @@map("payouts")
}

model EarningsPattern {
  id           String   @id @default(uuid())
  worker_id    String
  day_of_week  Int
  hour_slot    Int
  avg_earnings Float    @default(0)
  order_count  Int      @default(0)
  sample_weeks Int      @default(0)
  updated_at   DateTime @default(now()) @updatedAt

  worker Worker @relation(fields: [worker_id], references: [id])

  @@unique([worker_id, day_of_week, hour_slot])
  @@map("earnings_patterns")
}

model FraudRing {
  id               String    @id @default(uuid())
  ring_id          String
  member_count     Int
  detection_method String?
  center_latitude  Float?
  center_longitude Float?
  radius_meters    Int?
  member_worker_ids Json
  shared_signals   Json?
  status           String    @default("DETECTED")
  frozen_amount    Float     @default(0)
  detected_at      DateTime  @default(now())
  resolved_at      DateTime?
  resolved_by      String?
  notes            String?
  created_at       DateTime  @default(now())

  resolver Worker? @relation("FraudRingResolver", fields: [resolved_by], references: [id])

  @@map("fraud_rings")
}

model AuditLog {
  id                 String   @id @default(uuid())
  entity_type        String
  entity_id          String
  action             String
  actor_id           String?
  actor_role         String?
  previous_state     Json?
  new_state          Json?
  ip_address         String?
  device_fingerprint String?
  entry_hash         String
  previous_hash      String?
  metadata           Json?
  created_at         DateTime @default(now())

  @@map("audit_log")
}

model OTPCode {
  id           String   @id @default(uuid())
  phone        String
  otp_hash     String
  attempts     Int      @default(0)
  max_attempts Int      @default(3)
  expires_at   DateTime
  used         Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("otp_codes")
}

model MovementSignature {
  id                     String   @id @default(uuid())
  worker_id              String
  signature_date         String
  avg_speed              Float?
  stop_count             Int?
  route_complexity       Float?
  active_hours           Float?
  zones_visited          Json?
  gps_points_count       Int?
  altitude_variance      Float?
  accelerometer_activity Float?
  created_at             DateTime @default(now())

  worker Worker @relation(fields: [worker_id], references: [id])

  @@unique([worker_id, signature_date])
  @@map("movement_signatures")
}
